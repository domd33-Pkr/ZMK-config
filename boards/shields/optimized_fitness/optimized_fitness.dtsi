#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <20>;
        rows = <1>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
            RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17) RC(0,18) RC(0,19)
        >;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        keys
            // Left half
            = <&key_physical_attrs 100 100 16 182 0 0 0>   // 1: Pinky
            , <&key_physical_attrs 100 100 116 53 0 0 0>   // 2: Ring Top
            , <&key_physical_attrs 100 100 216 0 0 0 0>    // 3: Middle Top
            , <&key_physical_attrs 100 100 316 63 0 0 0>   // 4: Index Top
            , <&key_physical_attrs 100 100 266 263 0 0 0>  // 5: Thumb 3 (Inner)
            
            , <&key_physical_attrs 100 100 116 153 0 0 0>  // 6: Ring Bottom
            , <&key_physical_attrs 100 100 216 100 0 0 0>  // 7: Middle Bottom
            , <&key_physical_attrs 100 100 316 163 0 0 0>  // 8: Index Bottom
            , <&key_physical_attrs 100 100 156 275 (-12) 0 0> // 9: Thumb 2 (Mid)
            , <&key_physical_attrs 100 100 52 309 (-24) 0 0> // 10: Thumb 1 (Outer)

            // Right half (Mirrored, X_OFFSET = 600)
            , <&key_physical_attrs 100 100 900 182 0 0 0>   // 11: Pinky
            , <&key_physical_attrs 100 100 800 53 0 0 0>    // 12: Ring Top
            , <&key_physical_attrs 100 100 700 0 0 0 0>     // 13: Middle Top
            , <&key_physical_attrs 100 100 600 63 0 0 0>    // 14: Index Top
            , <&key_physical_attrs 100 100 650 263 0 0 0>   // 15: Thumb 3 (Inner)

            , <&key_physical_attrs 100 100 800 153 0 0 0>   // 16: Ring Bottom
            , <&key_physical_attrs 100 100 700 100 0 0 0>   // 17: Middle Bottom
            , <&key_physical_attrs 100 100 600 163 0 0 0>   // 18: Index Bottom
            , <&key_physical_attrs 100 100 760 275 12 0 0>  // 19: Thumb 2 (Mid)
            , <&key_physical_attrs 100 100 864 309 24 0 0>  // 20: Thumb 1 (Outer)
            ;
    };
};
