#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <20>;
        rows = <1>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
            RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17) RC(0,18) RC(0,19)
        >;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        keys
            // Left half
            = <&key_physical_attrs 100 100 564 309 24 0 0>  // 1: Thumb 1 (Inner)
            , <&key_physical_attrs 100 100 459 275 12 0 0>  // 2: Thumb 2 (Mid)
            , <&key_physical_attrs 100 100 350 263 0 0 0>   // 3: Thumb 3 (Outer)
            , <&key_physical_attrs 100 100 300 63 0 0 0>    // 4: Index Top
            , <&key_physical_attrs 100 100 300 163 0 0 0>   // 5: Index Bottom
            , <&key_physical_attrs 100 100 200 0 0 0 0>     // 6: Middle Top
            , <&key_physical_attrs 100 100 200 100 0 0 0>   // 7: Middle Bottom
            , <&key_physical_attrs 100 100 100 53 0 0 0>    // 8: Ring Top
            , <&key_physical_attrs 100 100 100 153 0 0 0>   // 9: Ring Bottom
            , <&key_physical_attrs 100 100 0 182 0 0 0>     // 10: Pinky

            // Right half (Mirrored, X_OFFSET = 800)
            , <&key_physical_attrs 100 100 800 309 (-24) 0 0> // 11: Thumb 1 (Inner)
            , <&key_physical_attrs 100 100 905 275 (-12) 0 0> // 12: Thumb 2 (Mid)
            , <&key_physical_attrs 100 100 1014 263 0 0 0>    // 13: Thumb 3 (Outer)
            , <&key_physical_attrs 100 100 1064 63 0 0 0>     // 14: Index Top
            , <&key_physical_attrs 100 100 1064 163 0 0 0>    // 15: Index Bottom
            , <&key_physical_attrs 100 100 1164 0 0 0 0>      // 16: Middle Top
            , <&key_physical_attrs 100 100 1164 100 0 0 0>    // 17: Middle Bottom
            , <&key_physical_attrs 100 100 1264 53 0 0 0>     // 18: Ring Top
            , <&key_physical_attrs 100 100 1264 153 0 0 0>    // 19: Ring Bottom
            , <&key_physical_attrs 100 100 1364 182 0 0 0>    // 20: Pinky
            ;
    };
};
