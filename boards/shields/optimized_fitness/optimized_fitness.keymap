#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define DELTA RA(LS(D))
#define OHM RA(LS(Q))
#define DEGREE RA(LS(SEMI))

/ {
    behaviors {
        ht: hold_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "HOLD_TAP";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        mtl: mo_tap_layer {
            compatible = "zmk,behavior-hold-tap";
            label = "MO_TAP_LAYER";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&sl>;
        };
    };

    macros {
        single_tilde: single_tilde {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap &kp LS(GRAVE) &kp SPACE>;
        };
    };
    keymap {
        compatible = "zmk,keymap";

        layer_1 {
            bindings = <
                // Left hand (Index 1 to 10)
                &mo 5                      // 1
                &sl 1                      // 2
                &mo 7                      // 3
                &ht LS(Q) Q                // 4
                &ht LS(N) N                // 5
                &ht LS(D) D                // 6
                &ht LS(D) D                // 7
                &kp G                      // 8
                &kp P                      // 9
                &mo 3                      // 10

                // Right hand (Index 11 to 20)
                &ht LS(A) A                // 11
                &ht C C                    // 12
                &ht LS(O) O                // 13
                &ht LS(A) A                // 14
                &ht LS(I) I                // 15
                &ht LS(B) B                // 16
                &kp E                      // 17
                &ht LS(C) C                // 18
                &kp U                      // 19
                &kp LS(GRAVE)              // 20
            >;
        };

        layer_2 {
            bindings = <
                // Left hand (Index 1 to 10)
                &ht LS(W) W                // 1
                &trans                     // 2
                &kp X                      // 3
                &kp H                      // 4
                &kp Q                      // 5
                &trans                     // 6
                &ht RS(Z) Z                // 7
                &trans                     // 8
                &trans                     // 9
                &mo 2                      // 10

                // Right hand (Index 11 to 20)
                &ht LS(SQT) SQT            // 11
                &ht DOT COMMA              // 12
                &ht LS(SEMI) SEMI          // 13
                &kp LS(NUMBER_5)           // 14
                &kp Y                      // 15
                &kp LS(NUMBER_4)           // 16
                &kp J                      // 17
                &kp LS(NUMBER_3)           // 18
                &kp MINUS                  // 19
                &kp LS(GRAVE)              // 20
            >;
        };

        layer_3 {
            bindings = <
                // Left hand (Index 1 to 10)
                &trans                     // 1
                &mo 1                      // 2
                &mt LGUI LGUI              // 3
                &bt BT_SEL 2               // 4
                &bt BT_CLR                 // 5
                &bt BT_SEL 1               // 6
                &bt BT_SEL 4               // 7
                &bt BT_SEL 0               // 8
                &bt BT_SEL 3               // 9
                &trans                     // 10

                // Right hand (Index 11 to 20)
                &kp BSPC                   // 11
                &kp DEL                    // 12
                &kp LS(NUMBER_2)           // 13
                &kp LS(RET)                // 14
                &kp LS(TAB)                // 15
                &kp RET                    // 16
                &kp TAB                    // 17
                &trans                     // 18
                &trans                     // 19
                &kp ESC                    // 20
            >;
        };

        layer_4 {
            bindings = <
                // Left hand (Index 1 to 10)
                &to 4                      // 1
                &mo 2                      // 2
                &kp LGUI                   // 3
                &kp LALT                   // 4
                &kp RALT                   // 5
                &kp LSHIFT                 // 6
                &trans                     // 7
                &kp LCTRL                  // 8
                &trans                     // 9
                &trans                     // 10

                // Right hand (Index 11 to 20)
                &kp PG_DN                  // 11
                &kp PG_UP                  // 12
                &trans                     // 13
                &kp HOME                   // 14
                &kp LEFT                   // 15
                &kp UP                     // 16
                &kp DOWN                   // 17
                &kp END                    // 18
                &kp RIGHT                  // 19
                &trans                     // 20
            >;
        };

        layer_5 {
            bindings = <
                // Left hand (Index 1 to 10)
                &trans                     // 1
                &trans                     // 2
                &trans                     // 3
                &trans                     // 4
                &trans                     // 5
                &trans                     // 6
                &trans                     // 7
                &trans                     // 8
                &trans                     // 9
                &mo 3                      // 10

                // Right hand (Index 11 to 20)
                &kp LC(Z)                  // 11
                &kp LC(S)                  // 12
                &trans                     // 13
                &kp LC(V)                  // 14
                &kp LC(A)                  // 15
                &kp LC(C)                  // 16
                &kp LC(F)                  // 17
                &kp LC(X)                  // 18
                &kp LC(H)                  // 19
                &kp LC(Y)                  // 20
            >;
        };

        layer_6 {
            bindings = <
                // Left hand (Index 1 to 10)
                &trans                     // 1
                &trans                     // 2
                &trans                     // 3
                &kp LS(NUMBER_8)           // 4
                &kp FSLH                   // 5
                &kp LS(EQUAL)              // 6
                &kp MINUS                  // 7
                &kp LS(NUMBER_6)           // 8
                &kp EQUAL                  // 9
                &mo 6                      // 10

                // Right hand (Index 11 to 20)
                &kp NUMBER_7               // 11
                &kp NUMBER_8               // 12
                &kp NUMBER_9               // 13
                &ht LS(A) NUMBER_1         // 14
                &ht LS(D) NUMBER_4         // 15
                &ht LS(B) NUMBER_2         // 16
                &ht LS(E) NUMBER_5         // 17
                &ht LS(C) NUMBER_3         // 18
                &ht LS(F) NUMBER_6         // 19
                &kp NUMBER_0               // 20
            >;
        };

        layer_7 {
            bindings = <
                // Left hand (Index 1 to 10)
                &mo 5                      // 1
                &kp DELTA                  // 2
                &trans                     // 3
                &kp DEGREE                 // 4
                &kp BSLH                   // 5
                &kp OHM                    // 6
                &kp LS(BSLH)               // 7
                &kp LS(NUMBER_3)           // 8
                &kp LS(GRAVE)              // 9
                &trans                     // 10

                // Right hand (Index 11 to 20)
                &ht LS(SQT) SQT            // 11
                &ht DOT COMMA              // 12
                &ht LS(SEMI) SEMI          // 13
                &ht LS(NUMBER_0) LS(NUMBER_9)// 14
                &kp LS(NUMBER_7)           // 15
                &ht LS(RBKT) LS(LBKT)      // 16
                &kp LS(NUMBER_5)           // 17
                &ht RBKT LBKT              // 18
                &kp LS(NUMBER_4)           // 19
                &ht LS(DOT) LS(COMMA)      // 20
            >;
        };

        layer_8 {
            bindings = <
                // Left hand (Index 1 to 10)
                &trans                     // 1
                &trans                     // 2
                &trans                     // 3
                &trans                     // 4
                &trans                     // 5
                &trans                     // 6
                &trans                     // 7
                &trans                     // 8
                &trans                     // 9
                &trans                     // 10

                // Right hand (Index 11 to 20)
                &trans                     // 11
                &trans                     // 12
                &trans                     // 13
                &trans                     // 14
                &trans                     // 15
                &trans                     // 16
                &trans                     // 17
                &trans                     // 18
                &trans                     // 19
                &trans                     // 20
            >;
