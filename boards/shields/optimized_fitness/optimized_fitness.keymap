                &kp TAB                     // 12
                &trans                      // 13
                &kp BSPC                    // 14
                &kp LEFT                    // 15
                &kp UP                      // 16
                &kp DOWN                    // 17
                &kp DEL                     // 18
                &kp RIGHT                   // 19
                &kp ESC                     // 20
