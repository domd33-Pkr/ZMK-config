#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>


/ {
    behaviors {
        ht: hold_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "HOLD_TAP";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        mtl: mo_tap_layer {
            compatible = "zmk,behavior-hold-tap";
            label = "MO_TAP_LAYER";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&sl>;
        };
    };
    keymap {
        compatible = "zmk,keymap";

        layer_1 {
            bindings = <
                // Left hand (Index 1 to 10)
                &ht LS(S) S                 // 1  (P0.06)
                &ht LS(L) L                 // 2  (P0.08)
                &ht LS(D) D                 // 3  (P0.17)
                &ht ESC RET                 // 4  (P0.20)
                &ht LS(N) N                 // 5  (P0.22)
                &mtl 4 1                    // 6  (P0.24)
                &ht LS(R) R                 // 7  (P1.00)
                &ht LS(G) G                 // 8  (P0.11)
                &ht LS(P) P                 // 9  (P1.04)
                &ht ESC RET                 // 10  (P1.06)

                // Right hand (Index 11 to 20)
                &ht RSFT(A) A               // 11  (P0.06)
                &ht RSFT(C) C               // 12  (P0.08)
                &ht LS(O) O                 // 13  (P0.17)
                &ht LS(T) T                 // 14  (P0.20)
                &ht TAB SPC                 // 15  (P0.22)
                &ht LS(I) I                 // 16  (P0.24)
                &ht LS(E) E                 // 17  (P1.00)
                &ht LS(V) V                 // 18  (P0.11)
                &ht LS(U) U                 // 19  (P1.04)
                &ht DEL BSPC                // 20  (P1.06)
            >;
        };

        layer_2 {
            bindings = <
                // Left hand (Index 1 to 10)
                &mtl 5 2                    // 1
