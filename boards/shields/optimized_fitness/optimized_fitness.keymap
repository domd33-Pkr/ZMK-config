                &ht LS(X) X                 // 3
                &ht LS(H) H                 // 4
                &ht LS(Q) Q                 // 5
                &trans                      // 6
                &ht RSFT(Z) Z               // 7
                &trans                      // 8
                &trans                      // 9
                &trans                      // 10

                // Right hand (Index 11 to 20)
                &kp SQT                     // 11
                &kp COMMA                   // 12
                &kp DOT                     // 13
                &ht LS(F) F                 // 14
                &ht LS(Y) Y                 // 15
                &ht LS(W) W                 // 16
                &ht LS(J) J                 // 17
                &ht LS(B) B                 // 18
                &kp MINUS                   // 19
                &kp UNDER                   // 20
            >;
        };

        layer_3 {
            bindings = <
                // Left hand (Index 1 to 10)
                &mt LSHIFT LSHIFT           // 1
                &mt RSHIFT RSHIFT           // 2
                &mt LGUI LGUI               // 3
                &mt LALT LALT               // 4
                &mt RALT RALT               // 5
